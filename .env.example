# Optional defaults for the Target settings panel (non-secret only).
# Workspace URL and personal access token are entered in the web UI.

DATABRICKS_NOTEBOOK_DIR=/Workspace/Pentaho_Migration
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=default
DATABRICKS_DATA_DIR=/Volumes/workspace/default/rawdata
DATABRICKS_STORAGE_ACCOUNT=
DATABRICKS_CONTAINER=
DATABRICKS_UC_PATH_PREFIX=
DATABRICKS_MANAGED_TABLES=false
DATABRICKS_TARGET_FORMAT=delta
