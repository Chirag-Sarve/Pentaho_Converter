<?xml version="1.0" encoding="UTF-8"?>
<job>
  <name>Master</name>
  <entries>
    <entry>
      <name>Start</name>
      <type>SPECIAL</type>
      <start>Y</start>
    </entry>
    <entry>
      <name>Customer Load</name>
      <type>TRANS</type>
      <filename>${Internal.Job.Filename.Directory}/../Transformations/Customer_Load.ktr</filename>
      <transname>Customer_Load</transname>
    </entry>
    <entry>
      <name>Sales Load</name>
      <type>TRANS</type>
      <filename>${Internal.Job.Filename.Directory}/../Transformations/Sales_Load.ktr</filename>
      <transname>Sales_Load</transname>
    </entry>
    <entry>
      <name>Success</name>
      <type>SUCCESS</type>
    </entry>
  </entries>
  <hops>
    <hop><from>Start</from><to>Customer Load</to><enabled>Y</enabled></hop>
    <hop><from>Customer Load</from><to>Sales Load</to><enabled>Y</enabled></hop>
    <hop><from>Sales Load</from><to>Success</to><enabled>Y</enabled></hop>
  </hops>
</job>
