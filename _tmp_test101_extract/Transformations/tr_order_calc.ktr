<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>tr_order_calc</name>
    <description>TextFileInput → Constant → Calculator → ValueMapper → TextFileOutput</description>
  </info>
  <order>
    <hop><from>Read Orders</from><to>Add Currency</to><enabled>Y</enabled></hop>
    <hop><from>Add Currency</from><to>Calc Amount</to><enabled>Y</enabled></hop>
    <hop><from>Calc Amount</from><to>Map Status</to><enabled>Y</enabled></hop>
    <hop><from>Map Status</from><to>Write Orders</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>Read Orders</name>
    <type>TextFileInput</type>
    <file>
      <name>${Internal.Transformation.Filename.Directory}/../data/orders.csv</name>
    </file>
    <separator>,</separator>
    <header>Y</header>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>order_id</name><type>Integer</type></field>
      <field><name>customer_id</name><type>Integer</type></field>
      <field><name>product</name><type>String</type></field>
      <field><name>qty</name><type>Integer</type></field>
      <field><name>unit_price</name><type>Number</type></field>
      <field><name>status</name><type>String</type></field>
    </fields>
  </step>

  <step>
    <name>Add Currency</name>
    <type>Constant</type>
    <fields>
      <field><name>currency</name><type>String</type><value>USD</value></field>
    </fields>
  </step>

  <step>
    <name>Calc Amount</name>
    <type>Calculator</type>
    <calculation>
      <field_name>amount</field_name>
      <calc_type>MULTIPLY</calc_type>
      <field_a>qty</field_a>
      <field_b>unit_price</field_b>
      <value_type>Number</value_type>
    </calculation>
  </step>

  <step>
    <name>Map Status</name>
    <type>ValueMapper</type>
    <field_to_use>status</field_to_use>
    <target_field>status_label</target_field>
    <non_match_default>OTHER</non_match_default>
    <fields>
      <field><source_value>A</source_value><target_value>ACTIVE</target_value></field>
      <field><source_value>B</source_value><target_value>BLOCKED</target_value></field>
      <field><source_value>C</source_value><target_value>CANCELLED</target_value></field>
    </fields>
  </step>

  <step>
    <name>Write Orders</name>
    <type>TextFileOutput</type>
    <file>
      <name>${Internal.Transformation.Filename.Directory}/../data/orders_enriched_out</name>
      <extention>csv</extention>
    </file>
    <separator>,</separator>
    <header>Y</header>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>order_id</name><type>Integer</type></field>
      <field><name>customer_id</name><type>Integer</type></field>
      <field><name>product</name><type>String</type></field>
      <field><name>qty</name><type>Integer</type></field>
      <field><name>unit_price</name><type>Number</type></field>
      <field><name>amount</name><type>Number</type></field>
      <field><name>currency</name><type>String</type></field>
      <field><name>status_label</name><type>String</type></field>
    </fields>
  </step>
</transformation>
