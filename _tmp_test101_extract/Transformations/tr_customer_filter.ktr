<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>tr_customer_filter</name>
    <description>TextFileInput → FilterRows → SelectValues → TextFileOutput</description>
  </info>
  <order>
    <hop><from>Read Customers</from><to>Keep Active</to><enabled>Y</enabled></hop>
    <hop><from>Keep Active</from><to>Select Fields</to><enabled>Y</enabled></hop>
    <hop><from>Select Fields</from><to>Write Active</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>Read Customers</name>
    <type>TextFileInput</type>
    <file>
      <name>${Internal.Transformation.Filename.Directory}/../data/customers.csv</name>
    </file>
    <separator>,</separator>
    <header>Y</header>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>customer_id</name><type>Integer</type></field>
      <field><name>customer_name</name><type>String</type></field>
      <field><name>status</name><type>String</type></field>
      <field><name>region</name><type>String</type></field>
    </fields>
  </step>

  <step>
    <name>Keep Active</name>
    <type>FilterRows</type>
    <send_true_to>Select Fields</send_true_to>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>status</leftvalue>
        <function>=</function>
        <value><name>constant</name><type>String</type><text>ACTIVE</text></value>
      </condition>
    </compare>
  </step>

  <step>
    <name>Select Fields</name>
    <type>SelectValues</type>
    <fields>
      <field><name>customer_id</name></field>
      <field><name>customer_name</name></field>
      <field><name>region</name></field>
    </fields>
  </step>

  <step>
    <name>Write Active</name>
    <type>TextFileOutput</type>
    <file>
      <name>${Internal.Transformation.Filename.Directory}/../data/customers_active_out</name>
      <extention>csv</extention>
    </file>
    <separator>,</separator>
    <header>Y</header>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>customer_id</name><type>Integer</type></field>
      <field><name>customer_name</name><type>String</type></field>
      <field><name>region</name><type>String</type></field>
    </fields>
  </step>
</transformation>
