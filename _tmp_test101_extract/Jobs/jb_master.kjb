<?xml version="1.0" encoding="UTF-8"?>
<job>
  <name>jb_master</name>
  <description>Start → log → customer → orders → products → Success</description>
  <entries>
    <entry>
      <name>Start</name>
      <type>SPECIAL</type>
      <start>Y</start>
    </entry>
    <entry>
      <name>Log Start</name>
      <type>WRITE_TO_LOG</type>
      <logmessage>TEST_101 master job started</logmessage>
      <loglevel>BASIC</loglevel>
      <displayHeader>Y</displayHeader>
    </entry>
    <entry>
      <name>Customer Filter</name>
      <type>TRANS</type>
      <filename>${Internal.Job.Filename.Directory}/../Transformations/tr_customer_filter.ktr</filename>
      <transname>tr_customer_filter</transname>
    </entry>
    <entry>
      <name>Order Calc</name>
      <type>TRANS</type>
      <filename>${Internal.Job.Filename.Directory}/../Transformations/tr_order_calc.ktr</filename>
      <transname>tr_order_calc</transname>
    </entry>
    <entry>
      <name>Product Agg</name>
      <type>TRANS</type>
      <filename>${Internal.Job.Filename.Directory}/../Transformations/tr_product_agg.ktr</filename>
      <transname>tr_product_agg</transname>
    </entry>
    <entry>
      <name>Success</name>
      <type>SUCCESS</type>
    </entry>
  </entries>
  <hops>
    <hop><from>Start</from><to>Log Start</to><enabled>Y</enabled></hop>
    <hop><from>Log Start</from><to>Customer Filter</to><enabled>Y</enabled></hop>
    <hop><from>Customer Filter</from><to>Order Calc</to><enabled>Y</enabled></hop>
    <hop><from>Order Calc</from><to>Product Agg</to><enabled>Y</enabled></hop>
    <hop><from>Product Agg</from><to>Success</to><enabled>Y</enabled></hop>
  </hops>
</job>
