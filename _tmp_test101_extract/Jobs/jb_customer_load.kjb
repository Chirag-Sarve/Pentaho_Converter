<?xml version="1.0" encoding="UTF-8"?>
<job>
  <name>jb_customer_load</name>
  <description>Start → customer filter TRANS → Success</description>
  <entries>
    <entry>
      <name>Start</name>
      <type>SPECIAL</type>
      <start>Y</start>
    </entry>
    <entry>
      <name>Run Customer Filter</name>
      <type>TRANS</type>
      <filename>${Internal.Job.Filename.Directory}/../Transformations/tr_customer_filter.ktr</filename>
      <transname>tr_customer_filter</transname>
    </entry>
    <entry>
      <name>Success</name>
      <type>SUCCESS</type>
    </entry>
  </entries>
  <hops>
    <hop><from>Start</from><to>Run Customer Filter</to><enabled>Y</enabled></hop>
    <hop><from>Run Customer Filter</from><to>Success</to><enabled>Y</enabled></hop>
  </hops>
</job>
