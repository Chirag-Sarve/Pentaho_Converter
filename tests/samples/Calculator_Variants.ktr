<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>Calculator_Variants</name>
    <description>Calculator XML variants: short names, numeric IDs, long descriptions, multi-ops</description>
  </info>
  <order>
    <hop><from>Generate Rows</from><to>Calc short names</to><enabled>Y</enabled></hop>
    <hop><from>Calc short names</from><to>Calc numeric IDs</to><enabled>Y</enabled></hop>
    <hop><from>Calc numeric IDs</from><to>Calc long desc</to><enabled>Y</enabled></hop>
    <hop><from>Calc long desc</from><to>Calc multi ops</to><enabled>Y</enabled></hop>
    <hop><from>Calc multi ops</from><to>Calc unsupported</to><enabled>Y</enabled></hop>
    <hop><from>Calc unsupported</from><to>Calc empty</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>Generate Rows</name>
    <type>DataGrid</type>
    <fields>
      <field><name>qty</name><type>Integer</type></field>
      <field><name>price</name><type>Number</type></field>
      <field><name>rate</name><type>Number</type></field>
      <field><name>name</name><type>String</type></field>
      <field><name>order_date</name><type>Date</type></field>
      <field><name>tmp_a</name><type>Number</type></field>
    </fields>
    <data>
      <line>
        <item>2</item><item>10.5</item><item>5</item>
        <item>alice</item><item>2024-01-15</item><item>1</item>
      </line>
    </data>
  </step>

  <step>
    <name>Calc short names</name>
    <type>Calculator</type>
    <calculation>
      <field_name>line_total</field_name>
      <calc_type>MULTIPLY</calc_type>
      <field_a>qty</field_a>
      <field_b>price</field_b>
      <value_type>Number</value_type>
      <remove>N</remove>
    </calculation>
    <calculation>
      <field_name>name_upper</field_name>
      <calc_type>UPPER_CASE</calc_type>
      <field_a>name</field_a>
      <value_type>String</value_type>
    </calculation>
  </step>

  <step>
    <name>Calc numeric IDs</name>
    <type>Calculator</type>
    <calculation>
      <field_name>sum_ids</field_name>
      <calc_type>3</calc_type>
      <field_a>qty</field_a>
      <field_b>tmp_a</field_b>
      <value_type>Integer</value_type>
    </calculation>
    <calculation>
      <field_name>name_len</field_name>
      <calc_type>56</calc_type>
      <field_a>name</field_a>
      <value_type>Integer</value_type>
    </calculation>
  </step>

  <step>
    <name>Calc long desc</name>
    <type>Calculator</type>
    <calculation>
      <field_name>pct</field_name>
      <calc_type>100 * A / B</calc_type>
      <field_a>line_total</field_a>
      <field_b>rate</field_b>
      <value_type>Number</value_type>
    </calculation>
    <calculation>
      <field_name>diff</field_name>
      <calc_type>A - B</calc_type>
      <field_a>line_total</field_a>
      <field_b>tmp_a</field_b>
      <value_type>Number</value_type>
    </calculation>
  </step>

  <step>
    <name>Calc multi ops</name>
    <type>Calculator</type>
    <failIfNoFile>Y</failIfNoFile>
    <calculation>
      <field_name>days_out</field_name>
      <calc_type>ADD_DAYS</calc_type>
      <field_a>order_date</field_a>
      <field_b>1</field_b>
      <value_type>Date</value_type>
    </calculation>
    <calculation>
      <field_name>name_lower</field_name>
      <calc_type>LOWER</calc_type>
      <field_a>name</field_a>
      <value_type>String</value_type>
    </calculation>
    <calculation>
      <field_name>discounted</field_name>
      <calc_type>PERCENT_2</calc_type>
      <field_a>line_total</field_a>
      <field_b>rate</field_b>
      <value_type>Number</value_type>
      <remove>Y</remove>
    </calculation>
  </step>

  <step>
    <name>Calc unsupported</name>
    <type>Calculator</type>
    <calculation>
      <field_name>jaro_score</field_name>
      <calc_type>JARO</calc_type>
      <field_a>name</field_a>
      <field_b>name_upper</field_b>
      <value_type>Number</value_type>
    </calculation>
  </step>

  <step>
    <name>Calc empty</name>
    <type>Calculator</type>
  </step>
</transformation>
