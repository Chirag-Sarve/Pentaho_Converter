<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>Generator_Audit_Workflow</name>
    <description>Representative executable workflow for generator audit (DataGrid→Calc→Filter→Select→ValueMapper→SystemInfo→Abort threshold)</description>
  </info>
  <order>
    <hop><from>Generate Rows</from><to>Add constants</to><enabled>Y</enabled></hop>
    <hop><from>Add constants</from><to>Calc metrics</to><enabled>Y</enabled></hop>
    <hop><from>Calc metrics</from><to>Filter active</to><enabled>Y</enabled></hop>
    <hop><from>Filter active</from><to>Select values</to><enabled>Y</enabled></hop>
    <hop><from>Select values</from><to>Map status</to><enabled>Y</enabled></hop>
    <hop><from>Map status</from><to>System info</to><enabled>Y</enabled></hop>
    <hop><from>System info</from><to>Guard abort</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>Generate Rows</name>
    <type>DataGrid</type>
    <fields>
      <field><name>id</name><type>Integer</type></field>
      <field><name>name</name><type>String</type></field>
      <field><name>qty</name><type>Integer</type></field>
      <field><name>price</name><type>Number</type></field>
      <field><name>status</name><type>String</type></field>
    </fields>
    <data>
      <line><item>1</item><item>Alice</item><item>2</item><item>10</item><item>A</item></line>
      <line><item>2</item><item>Bob</item><item>3</item><item>20</item><item>B</item></line>
    </data>
  </step>

  <step>
    <name>Add constants</name>
    <type>Constant</type>
    <fields>
      <field><name>currency</name><type>String</type><value>USD</value></field>
    </fields>
  </step>

  <step>
    <name>Calc metrics</name>
    <type>Calculator</type>
    <calculation>
      <field_name>total</field_name>
      <calc_type>MULTIPLY</calc_type>
      <field_a>qty</field_a>
      <field_b>price</field_b>
      <value_type>Number</value_type>
    </calculation>
    <calculation>
      <field_name>name_u</field_name>
      <calc_type>UPPER_CASE</calc_type>
      <field_a>name</field_a>
      <value_type>String</value_type>
    </calculation>
  </step>

  <step>
    <name>Filter active</name>
    <type>FilterRows</type>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>status</leftvalue>
        <function>=</function>
        <value><type>String</type><text>A</text></value>
      </condition>
    </compare>
  </step>

  <step>
    <name>Select values</name>
    <type>SelectValues</type>
    <fields>
      <field><name>id</name></field>
      <field><name>name_u</name><rename>name</rename></field>
      <field><name>total</name></field>
      <field><name>status</name></field>
      <field><name>currency</name></field>
    </fields>
  </step>

  <step>
    <name>Map status</name>
    <type>ValueMapper</type>
    <field_to_use>status</field_to_use>
    <target_field>status_label</target_field>
    <non_match_default>UNKNOWN</non_match_default>
    <fields>
      <field><source_value>A</source_value><target_value>ACTIVE</target_value></field>
      <field><source_value>B</source_value><target_value>BLOCKED</target_value></field>
      <field><source_value/><target_value>EMPTY</target_value></field>
    </fields>
  </step>

  <step>
    <name>System info</name>
    <type>SystemInfo</type>
    <fields>
      <field><name>run_date</name><type>system date (variable)</type></field>
      <field><name>run_ts</name><type>system datetime (variable)</type></field>
    </fields>
  </step>

  <step>
    <name>Guard abort</name>
    <type>Abort</type>
    <row_threshold>1000000</row_threshold>
    <message>Should not abort on audit sample</message>
  </step>
</transformation>
