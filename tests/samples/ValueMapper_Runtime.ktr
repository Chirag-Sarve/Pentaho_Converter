<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>ValueMapper_Runtime</name>
    <description>Multi-mapping Value Mapper with default and empty-source mapping</description>
  </info>
  <order>
    <hop><from>Generate</from><to>Map status</to><enabled>Y</enabled></hop>
  </order>
  <step>
    <name>Generate</name>
    <type>DataGrid</type>
    <fields>
      <field><name>status</name><type>String</type></field>
    </fields>
    <data>
      <line><item>A</item></line>
      <line><item>B</item></line>
      <line><item>Z</item></line>
      <line><item></item></line>
    </data>
  </step>
  <step>
    <name>Map status</name>
    <type>ValueMapper</type>
    <field_to_use>status</field_to_use>
    <target_field>label</target_field>
    <non_match_default>OTHER</non_match_default>
    <case_sensitive>Y</case_sensitive>
    <valuemap>
      <source_value>A</source_value>
      <target_value>ACTIVE</target_value>
    </valuemap>
    <valuemap>
      <source_value>B</source_value>
      <target_value>BETA</target_value>
    </valuemap>
    <valuemap>
      <source_value/>
      <target_value>EMPTY</target_value>
    </valuemap>
  </step>
</transformation>
