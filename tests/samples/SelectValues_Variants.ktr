<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>SelectValues_Variants</name>
    <description>Select Values XML variants: select/rename/remove/meta/unspecified/step-level</description>
  </info>
  <order>
    <hop><from>Generate Rows</from><to>SV select rename</to><enabled>Y</enabled></hop>
    <hop><from>SV select rename</from><to>SV remove under fields</to><enabled>Y</enabled></hop>
    <hop><from>SV remove under fields</from><to>SV meta only</to><enabled>Y</enabled></hop>
    <hop><from>SV meta only</from><to>SV remove step level</to><enabled>Y</enabled></hop>
    <hop><from>SV remove step level</from><to>SV select unspecified</to><enabled>Y</enabled></hop>
    <hop><from>SV select unspecified</from><to>SV full meta</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>Generate Rows</name>
    <type>DataGrid</type>
    <fields>
      <field><name>customer_id</name><type>Integer</type></field>
      <field><name>customer_name</name><type>String</type></field>
      <field><name>amount</name><type>Number</type></field>
      <field><name>status</name><type>String</type></field>
      <field><name>tmp_col</name><type>String</type></field>
      <field><name>debug</name><type>String</type></field>
      <field><name>as_of</name><type>String</type></field>
    </fields>
    <data>
      <line>
        <item>1</item><item>Alice</item><item>12.5</item>
        <item>ACTIVE</item><item>x</item><item>y</item><item>2024-06-01</item>
      </line>
    </data>
  </step>

  <step>
    <name>SV select rename</name>
    <type>SelectValues</type>
    <fields>
      <field><name>customer_id</name><rename>id</rename><length>10</length><precision>0</precision></field>
      <field><name>customer_name</name><rename>name</rename></field>
      <field><name>amount</name></field>
      <field><name>status</name></field>
      <field><name>tmp_col</name></field>
      <field><name>debug</name></field>
      <field><name>as_of</name></field>
    </fields>
  </step>

  <step>
    <name>SV remove under fields</name>
    <type>SelectValues</type>
    <fields>
      <field><name>id</name></field>
      <field><name>name</name></field>
      <field><name>amount</name></field>
      <field><name>status</name></field>
      <field><name>tmp_col</name></field>
      <field><name>debug</name></field>
      <field><name>as_of</name></field>
      <remove><name>tmp_col</name></remove>
      <remove><name>debug</name></remove>
    </fields>
  </step>

  <step>
    <name>SV meta only</name>
    <type>SelectValues</type>
    <fields>
      <meta>
        <name>amount</name>
        <type>Integer</type>
        <length>9</length>
        <precision>0</precision>
      </meta>
      <meta>
        <name>as_of</name>
        <type>Date</type>
        <conversion_mask>yyyy-MM-dd</conversion_mask>
      </meta>
    </fields>
  </step>

  <step>
    <name>SV remove step level</name>
    <type>SelectValues</type>
    <remove><name>status</name></remove>
    <fields>
      <field><name>id</name></field>
      <field><name>name</name></field>
      <field><name>amount</name></field>
      <field><name>as_of</name></field>
    </fields>
  </step>

  <step>
    <name>SV select unspecified</name>
    <type>SelectValues</type>
    <fields>
      <field><name>id</name><rename>cust_id</rename></field>
      <select_unspecified>Y</select_unspecified>
    </fields>
  </step>

  <step>
    <name>SV full meta</name>
    <type>SelectValues</type>
    <fields>
      <field><name>cust_id</name></field>
      <field><name>name</name><rename>full_name</rename><type>String</type><length>40</length></field>
      <field><name>amount</name></field>
      <meta>
        <name>amount</name>
        <rename>amt</rename>
        <type>1</type>
        <length>12</length>
        <precision>2</precision>
        <conversion_mask>#,##0.00</conversion_mask>
        <decimal_symbol>.</decimal_symbol>
        <grouping_symbol>,</grouping_symbol>
        <currency_symbol>$</currency_symbol>
        <encoding>UTF-8</encoding>
        <storage_type>normal</storage_type>
      </meta>
    </fields>
  </step>
</transformation>
