<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>TextFile_Write_Read</name>
    <description>Text File Output then Text File Input — runtime paths must match</description>
  </info>
  <order>
    <hop><from>Generate</from><to>WriteCSV</to><enabled>Y</enabled></hop>
    <hop><from>WriteCSV</from><to>ReadCSV</to><enabled>Y</enabled></hop>
  </order>
  <step>
    <name>Generate</name>
    <type>DataGrid</type>
    <fields>
      <field><name>id</name><type>Integer</type></field>
      <field><name>name</name><type>String</type></field>
    </fields>
    <data>
      <line><item>1</item><item>alice</item></line>
      <line><item>2</item><item>bob</item></line>
    </data>
  </step>
  <step>
    <name>WriteCSV</name>
    <type>TextFileOutput</type>
    <file>
      <name>C:\pentaho\data\runtime_orders</name>
      <extention>csv</extention>
    </file>
    <separator>,</separator>
    <header>Y</header>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>id</name><type>Integer</type></field>
      <field><name>name</name><type>String</type></field>
    </fields>
  </step>
  <step>
    <name>ReadCSV</name>
    <type>TextFileInput</type>
    <file>
      <name>${Internal.Transformation.Filename.Directory}/runtime_orders.csv</name>
    </file>
    <separator>,</separator>
    <header>Y</header>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>id</name><type>Integer</type></field>
      <field><name>name</name><type>String</type></field>
    </fields>
  </step>
</transformation>
